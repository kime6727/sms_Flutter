# ======================================================================
# SMS 接码平台 - 环境变量配置模板
# ======================================================================
# 使用方法:
#   1. 复制本文件为 .env:  cp .env.example .env
#   2. 填写真实值（密码、密钥等）
#   3. .env 已加入 .gitignore，禁止提交到版本控制
# ======================================================================

# ----------------------------------------------------------------------
# 数据库配置
# ----------------------------------------------------------------------
# 本地开发（默认）:
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=sms_receiver
# DB_USER=root
# DB_PASS=

# TiDB Cloud 生产环境示例:
#   1. 在 TiDB Cloud 控制台 Cluster -> SQL Editor 创建数据库 sms_receiver
#      (TiDB Cloud SQL Editor 不允许 CREATE DATABASE)
#   2. 在 SQL Editor 顶部 database 下拉框选 sms_receiver
#   3. 把 backend/database.sql 内容粘贴进去执行
#   4. 从 TiDB Cloud Connect 弹窗获取连接信息填到下方
# DB_HOST=gateway01.ap-southeast-1.prod.alicloud.tidbcloud.com
# DB_PORT=4000
# DB_NAME=sms_receiver
# DB_USER=xxxxxxxx.root
# DB_PASS=xxxxxxxx

DB_HOST=localhost
DB_PORT=3306
DB_NAME=sms_receiver
DB_USER=root
DB_PASS=

# ----------------------------------------------------------------------
# SSL 配置（TiDB Cloud / 阿里云 RDS / AWS RDS 强制启用）
# ----------------------------------------------------------------------
# 启用 SSL: DB_SSL_ENABLED=1
# 方式 A: 传 CA 文件路径（容器内挂载的证书）
# DB_SSL_CA=/etc/ssl/cert.pem
# 方式 B: 传 CA 证书内容（base64 编码，最安全/最易用）
# 获取: curl -sS https://letsencrypt.org/certs/isrgrootx1.pem | base64 -w 0
# DB_SSL_CA_CONTENT=LS0tLS1CRUdJTi...
# 是否校验服务端证书: 生产必须 true, 自签证书时临时设为 false
DB_SSL_VERIFY=true
DB_SSL_ENABLED=0

# ----------------------------------------------------------------------
# API 配置
# ----------------------------------------------------------------------
# 生成随机 API Key: openssl rand -hex 32
API_KEY=your_random_api_key_here
HEROSMS_API_KEY=your_herosms_api_key_here
HEROSMS_BASE_URL=https://hero-sms.com/stubs/handler_api.php

# ----------------------------------------------------------------------
# Apple IAP 配置
# ----------------------------------------------------------------------
APPLE_SHARED_SECRET=your_apple_shared_secret_here

# ----------------------------------------------------------------------
# 认证密钥（用于 Token 签名）
# ----------------------------------------------------------------------
# 生成: openssl rand -hex 32
AUTH_SECRET_KEY=your_random_auth_secret_here

# ----------------------------------------------------------------------
# 应用配置
# ----------------------------------------------------------------------
APP_NAME=SMS 接码平台
# APP_URL 必须是公网可访问的 HTTPS 地址，hero-sms webhook 用此地址回传
APP_URL=https://your-domain.com
# 生产环境必须设为 production
APP_ENV=production

# ----------------------------------------------------------------------
# CORS 配置（生产环境必须限制来源）
# ----------------------------------------------------------------------
# 多个域名用逗号分隔，例如: https://app1.com,https://app2.com
# 生产环境禁止使用 *
CORS_ALLOWED_ORIGINS=https://your-domain.com
